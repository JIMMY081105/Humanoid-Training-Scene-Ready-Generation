+@dataclass(frozen=True)
+class _ArtiverseMeshResource:
+    path: Path
+    transform: np.ndarray
+    uniform_scale: float
+
+
+@dataclass(frozen=True)
+class _ArtiverseLinkMeshRecord:
+    """SDF-authored mesh resources for one normalized Artiverse link."""
+
+    link_name: str
+    visual_mesh: _ArtiverseMeshResource
+    collision_meshes: tuple[_ArtiverseMeshResource, ...]
+
+
+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as handle:
+        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _regular_file_within(
+    raw_uri: str,
+    *,
+    sdf_dir: Path,
+    label: str,
+    allowed_suffixes: frozenset[str],
+) -> tuple[Path, PurePosixPath]:
+    """Resolve one plain relative SDF URI without permitting path substitution."""
+
+    if not raw_uri or raw_uri != raw_uri.strip() or "\\" in raw_uri or "%" in raw_uri:
+        raise ValueError(f"{label} has an unsafe or empty URI: {raw_uri!r}")
+    parsed = urlsplit(raw_uri)
+    if parsed.scheme or parsed.netloc or parsed.query or parsed.fragment:
+        raise ValueError(f"{label} URI is not a plain relative path: {raw_uri!r}")
+    if not parsed.path.startswith("./"):
+        raise ValueError(f"{label} URI must use canonical './' form: {raw_uri!r}")
+    relative = PurePosixPath(parsed.path[2:])
+    if (
+        relative.is_absolute()
+        or not relative.parts
+        or any(part in {"", ".", ".."} for part in relative.parts)
+        or relative.suffix.lower() not in allowed_suffixes
+    ):
+        raise ValueError(f"{label} URI is unsafe or unsupported: {raw_uri!r}")
+
+    root = sdf_dir.resolve(strict=True)
+    candidate = sdf_dir.joinpath(*relative.parts)
+    current = candidate
+    while current != sdf_dir:
+        if current.is_symlink():
+            raise ValueError(f"{label} resource is a symlink: {candidate}")
+        current = current.parent
+    try:
+        resolved = candidate.resolve(strict=True)
+    except OSError as exc:
+        raise FileNotFoundError(f"{label} resource is missing: {candidate}") from exc
+    if not resolved.is_relative_to(root):
+        raise ValueError(f"{label} resource escapes the Artiverse asset: {candidate}")
+    mode = os.stat(resolved, follow_symlinks=False).st_mode
+    if not stat.S_ISREG(mode):
+        raise ValueError(f"{label} resource is not a regular file: {candidate}")
+    return resolved, relative
+
+
+def _sdf_pose_matrix(
+    pose: ET.Element | None,
+    *,
+    label: str,
+    allowed_attributes: frozenset[str] = frozenset(),
+) -> np.ndarray:
+    unexpected_attributes = (
+        set(pose.attrib) - allowed_attributes if pose is not None else set()
+    )
+    if unexpected_attributes:
+        raise ValueError(
+            f"{label} uses unsupported pose attributes: "
+            f"{sorted(unexpected_attributes)}"
+        )
+    raw = (pose.text or "").strip() if pose is not None else ""
+    values = [0.0] * 6 if not raw else [float(item) for item in raw.split()]
+    if len(values) != 6 or not np.all(np.isfinite(values)):
+        raise ValueError(f"{label} must contain six finite pose values")
+    x, y, z, roll, pitch, yaw = values
+    cr, sr = math.cos(roll), math.sin(roll)
+    cp, sp = math.cos(pitch), math.sin(pitch)
+    cy, sy = math.cos(yaw), math.sin(yaw)
+    rotation_x = np.array([[1, 0, 0], [0, cr, -sr], [0, sr, cr]])
+    rotation_y = np.array([[cp, 0, sp], [0, 1, 0], [-sp, 0, cp]])
+    rotation_z = np.array([[cy, -sy, 0], [sy, cy, 0], [0, 0, 1]])
+    result = np.eye(4)
+    result[:3, :3] = rotation_z @ rotation_y @ rotation_x
+    result[:3, 3] = [x, y, z]
+    return result
+
+
+def _uniform_mesh_scale(mesh: ET.Element, *, label: str) -> float:
+    raw = (mesh.findtext("scale") or "").strip()
+    if not raw:
+        return 1.0
+    values = [float(item) for item in raw.split()]
+    if (
+        len(values) != 3
+        or not np.all(np.isfinite(values))
+        or any(value <= 0 for value in values)
+        or max(values) - min(values) > 1e-9
+    ):
+        raise ValueError(f"{label} must use one finite positive uniform mesh scale")
+    return values[0]
+
+
+def _resolve_artiverse_link_transforms(
+    root: ET.Element,
+) -> tuple[dict[str, ET.Element], dict[str, np.ndarray]]:
+    models = root.findall("model")
+    if len(models) != 1:
+        raise ValueError("Normalized Artiverse SDF must contain exactly one model")
+    model = models[0]
+    model_transform = _sdf_pose_matrix(
+        model.find("pose"), label="normalized Artiverse model pose"
+    )
+    if not np.allclose(model_transform, np.eye(4), rtol=0.0, atol=1e-12):
+        raise ValueError("Normalized Artiverse model pose must be identity")
+    links: dict[str, ET.Element] = {}
+    for link in model.findall("link"):
+        link_name = (link.get("name") or "").strip()
+        if not link_name or link_name in links:
+            raise ValueError(
+                f"Artiverse SDF has an empty or duplicate link name: {link_name!r}"
+            )
+        links[link_name] = link
+
+    resolved: dict[str, np.ndarray] = {}
+    active: set[str] = set()
+
+    def resolve(link_name: str) -> np.ndarray:
+        if link_name in resolved:
+            return resolved[link_name]
+        if link_name in active:
+            raise ValueError(f"Artiverse SDF link pose cycle includes {link_name!r}")
+        active.add(link_name)
+        pose = links[link_name].find("pose")
+        relative_to = (pose.get("relative_to") or "").strip() if pose is not None else ""
+        parent = np.eye(4)
+        if relative_to and relative_to not in {"__model__", "world"}:
+            if relative_to not in links:
+                raise ValueError(
+                    f"Artiverse link {link_name!r} references unknown frame {relative_to!r}"
+                )
+            parent = resolve(relative_to)
+        result = parent @ _sdf_pose_matrix(
+            pose,
+            label=f"link {link_name!r} pose",
+            allowed_attributes=frozenset({"relative_to"}),
+        )
+        active.remove(link_name)
+        resolved[link_name] = result
+        return result
+
+    for name in links:
+        resolve(name)
+    return links, resolved
+
+
+def _geometry_mesh_resource(
+    element: ET.Element,
+    *,
+    sdf_dir: Path,
+    link_transform: np.ndarray,
+    label: str,
+    allowed_suffixes: frozenset[str],
+) -> tuple[Path, PurePosixPath, np.ndarray, float]:
+    pose = element.find("pose")
+    if pose is not None and (pose.get("relative_to") or "").strip():
+        raise ValueError(f"{label} uses an unsupported explicit pose frame")
+    geometries = element.findall("geometry")
+    mesh = element.find("geometry/mesh")
+    if (
+        mesh is None
+        or len(geometries) != 1
+        or len(list(geometries[0])) != 1
+        or list(geometries[0])[0] is not mesh
+    ):
+        raise ValueError(f"{label} must contain exactly one mesh geometry")
+    uri = mesh.findtext("uri") or ""
+    path, relative = _regular_file_within(
+        uri,
+        sdf_dir=sdf_dir,
+        label=label,
+        allowed_suffixes=allowed_suffixes,
+    )
+    transform = link_transform @ _sdf_pose_matrix(pose, label=f"{label} pose")
+    scale = _uniform_mesh_scale(mesh, label=label)
+    return path, relative, transform, scale
+
+
+def _validated_artiverse_manifest(
+    sdf_dir: Path, visual_relatives: set[PurePosixPath]
+) -> None:
+    """Bind normalized visual glTFs to their immutable derivation manifest."""
+
+    manifest_path = sdf_dir / "scenesmith_artiverse_visuals_v2" / "_derivation_manifest.json"
+    if manifest_path.is_symlink() or not manifest_path.is_file():
+        raise FileNotFoundError(
+            f"Normalized Artiverse visual derivation manifest is missing: {manifest_path}"
+        )
+    try:
+        document = json.loads(manifest_path.read_text(encoding="utf-8"))
+    except (OSError, UnicodeDecodeError, json.JSONDecodeError) as exc:
+        raise ValueError(f"Invalid Artiverse visual derivation manifest: {manifest_path}") from exc
+    expected_document_keys = {
+        "schema_version",
+        "status",
+        "policy",
+        "resource_directory",
+        "resources",
+    }
+    if (
+        not isinstance(document, dict)
+        or set(document) != expected_document_keys
+        or document.get("schema_version") != 2
+        or document.get("status") != "pass"
+        or document.get("policy") != "publisher_glb_derived_external_gltf"
+        or document.get("resource_directory") != "scenesmith_artiverse_visuals_v2"
+        or not isinstance(document.get("resources"), list)
+    ):
+        raise ValueError(f"Unexpected Artiverse visual derivation contract: {manifest_path}")
+
+    manifest_visuals: set[PurePosixPath] = set()
+    expected_derived_entries = {"_derivation_manifest.json"}
+    casefolded_resource_names: set[str] = set()
+    expected_resource_keys = {
+        "part",
+        "publisher_glb_sha256",
+        "publisher_glb_size_bytes",
+        "publisher_document_sha256",
+        "preserved_semantics_sha256",
+        "derived_gltf",
+        "derived_gltf_sha256",
+        "derived_gltf_size_bytes",
+        "derived_bin",
+        "derived_bin_sha256",
+        "derived_bin_size_bytes",
+    }
+    for index, item in enumerate(document["resources"]):
+        if not isinstance(item, dict) or set(item) != expected_resource_keys:
+            raise ValueError(f"Artiverse derivation record {index} is not an object")
+        part = item.get("part")
+        gltf_name = item.get("derived_gltf")
+        bin_name = item.get("derived_bin")
+        if (
+            not isinstance(part, str)
+            or not part
+            or PurePosixPath(part).name != part
+            or
+            not isinstance(gltf_name, str)
+            or not isinstance(bin_name, str)
+            or PurePosixPath(gltf_name).name != gltf_name
+            or PurePosixPath(bin_name).name != bin_name
+            or gltf_name != f"{part}.gltf"
+            or bin_name != f"{part}.bin"
+        ):
+            raise ValueError(f"Artiverse derivation record {index} has unsafe resource names")
+        for name in (gltf_name, bin_name):
+            if name.casefold() in casefolded_resource_names:
+                raise ValueError(f"Duplicate Artiverse derivation resource: {name}")
+            casefolded_resource_names.add(name.casefold())
+            expected_derived_entries.add(name)
+        gltf_relative = PurePosixPath("scenesmith_artiverse_visuals_v2") / gltf_name
+        if gltf_relative in manifest_visuals:
+            raise ValueError(f"Duplicate Artiverse derivation resource: {gltf_name}")
+        manifest_visuals.add(gltf_relative)
+        resources: dict[str, Path] = {}
+        for key, name in (("derived_gltf", gltf_name), ("derived_bin", bin_name)):
+            path = manifest_path.parent / name
+            if path.is_symlink() or not path.is_file():
+                raise FileNotFoundError(f"Artiverse derived resource is missing: {path}")
+            expected_size = item.get(f"{key}_size_bytes")
+            expected_sha = item.get(f"{key}_sha256")
+            if (
+                not isinstance(expected_size, int)
+                or expected_size <= 0
+                or path.stat().st_size != expected_size
+                or not isinstance(expected_sha, str)
+                or len(expected_sha) != 64
+                or _sha256_file(path) != expected_sha
+            ):
+                raise ValueError(f"Artiverse derived resource does not match manifest: {path}")
+            resources[key] = path
+        publisher_path, _ = _regular_file_within(
+            f"./glbs/{part}.glb",
+            sdf_dir=sdf_dir,
+            label=f"Artiverse derivation record {index} publisher GLB",
+            allowed_suffixes=frozenset({".glb"}),
+        )
+        if (
+            isinstance(item["publisher_glb_size_bytes"], bool)
+            or not isinstance(item["publisher_glb_size_bytes"], int)
+            or item["publisher_glb_size_bytes"] <= 0
+            or publisher_path.stat().st_size != item["publisher_glb_size_bytes"]
+            or not isinstance(item["publisher_glb_sha256"], str)
+            or not re.fullmatch(r"[0-9a-f]{64}", item["publisher_glb_sha256"])
+            or _sha256_file(publisher_path) != item["publisher_glb_sha256"]
+        ):
+            raise ValueError(
+                f"Artiverse publisher GLB does not match manifest: {publisher_path}"
+            )
+        for key in ("publisher_document_sha256", "preserved_semantics_sha256"):
+            if not isinstance(item[key], str) or not re.fullmatch(
+                r"[0-9a-f]{64}", item[key]
+            ):
+                raise ValueError(f"Artiverse derivation record {index} has invalid {key}")
+        try:
+            gltf_document = json.loads(resources["derived_gltf"].read_text(encoding="utf-8"))
+        except (UnicodeDecodeError, json.JSONDecodeError) as exc:
+            raise ValueError(
+                f"Artiverse derived glTF is not valid UTF-8 JSON: {resources['derived_gltf']}"
+            ) from exc
+        buffers = gltf_document.get("buffers") if isinstance(gltf_document, dict) else None
+        if (
+            not isinstance(buffers, list)
+            or len(buffers) != 1
+            or not isinstance(buffers[0], dict)
+            or buffers[0].get("uri") != bin_name
+            or buffers[0].get("byteLength") != resources["derived_bin"].stat().st_size
+        ):
+            raise ValueError(
+                f"Artiverse derived glTF does not bind its exact manifest bin: "
+                f"{resources['derived_gltf']}"
+            )
+
+        preserved_document = copy.deepcopy(gltf_document)
+        del preserved_document["buffers"][0]["uri"]
+        preserved_payload = (
+            json.dumps(
+                preserved_document,
+                ensure_ascii=False,
+                sort_keys=True,
+                separators=(",", ":"),
+            )
+            + "\n"
+        ).encode("utf-8")
+        if (
+            hashlib.sha256(preserved_payload).hexdigest()
+            != item["preserved_semantics_sha256"]
+        ):
+            raise ValueError(
+                f"Artiverse derived glTF semantics do not match manifest: "
+                f"{resources['derived_gltf']}"
+            )
+
+        transitive_uris: list[str] = []
+
+        def collect_uris(value: Any) -> None:
+            if isinstance(value, dict):
+                for key, child in value.items():
+                    if key == "uri":
+                        if not isinstance(child, str):
+                            raise ValueError("Artiverse glTF URI is not a string")
+                        transitive_uris.append(child)
+                    else:
+                        collect_uris(child)
+            elif isinstance(value, list):
+                for child in value:
+                    collect_uris(child)
+
+        collect_uris(gltf_document)
+        if transitive_uris != [bin_name]:
+            raise ValueError(
+                f"Artiverse derived glTF has unexpected transitive URIs: "
+                f"{resources['derived_gltf']} -> {transitive_uris}"
+            )
+    actual_derived_entries = {path.name for path in manifest_path.parent.iterdir()}
+    if actual_derived_entries != expected_derived_entries or any(
+        path.is_symlink() or not path.is_file() for path in manifest_path.parent.iterdir()
+    ):
+        raise ValueError(
+            "Artiverse derived resource directory inventory mismatch: "
+            f"missing={sorted(expected_derived_entries - actual_derived_entries)}, "
+            f"extra={sorted(actual_derived_entries - expected_derived_entries)}"
+        )
+    if manifest_visuals != visual_relatives:
+        missing = sorted(str(path) for path in visual_relatives - manifest_visuals)
+        extra = sorted(str(path) for path in manifest_visuals - visual_relatives)
+        raise ValueError(
+            "Artiverse SDF/derivation visual inventory mismatch: "
+            f"missing={missing}, extra={extra}"
+        )
+
+
+def _parse_artiverse_link_meshes(
+    sdf_path: Path, sdf_dir: Path
+) -> list[_ArtiverseLinkMeshRecord]:
+    """Read normalized Artiverse link meshes from the authoritative copied SDF."""
+
+    if sdf_path.name != "scenesmith_artiverse.sdf":
+        raise ValueError(f"Not a normalized Artiverse SDF: {sdf_path}")
+    if sdf_path.is_symlink() or not sdf_path.is_file():
+        raise ValueError(f"Normalized Artiverse SDF is not a regular file: {sdf_path}")
+    if sdf_path.resolve(strict=True).parent != sdf_dir.resolve(strict=True):
+        raise ValueError("Artiverse SDF must be located directly inside its asset directory")
+    try:
+        root = ET.parse(sdf_path).getroot()
+    except (OSError, ET.ParseError) as exc:
+        raise ValueError(f"Cannot parse normalized Artiverse SDF: {sdf_path}") from exc
+
+    links, link_transforms = _resolve_artiverse_link_transforms(root)
+    records: list[_ArtiverseLinkMeshRecord] = []
+    visual_paths: set[Path] = set()
+    collision_owners: dict[Path, str] = {}
+    visual_relatives: set[PurePosixPath] = set()
+    for link_name, link in links.items():
+        visuals = link.findall("visual")
+        collision_elements = link.findall("collision")
+        if not visuals and not collision_elements:
+            # Multi-DOF conversion can emit a geometry-free proxy link. It has no
+            # surface authority and is intentionally absent from the manifest.
+            continue
+        if len(visuals) != 1 or not collision_elements:
+            raise ValueError(
+                f"Normalized Artiverse geometry link {link_name!r} must have one "
+                "visual and at least one collision mesh"
+            )
+        visual_path, visual_relative, visual_transform, visual_scale = (
+            _geometry_mesh_resource(
+                visuals[0],
+                sdf_dir=sdf_dir,
+                link_transform=link_transforms[link_name],
+                label=f"Artiverse link {link_name!r} visual",
+                allowed_suffixes=frozenset({".gltf"}),
+            )
+        )
+        if visual_relative.parent != PurePosixPath("scenesmith_artiverse_visuals_v2"):
+            raise ValueError(
+                f"Artiverse link {link_name!r} does not use normalized derived visuals"
+            )
+        if visual_path in visual_paths:
+            raise ValueError(f"Artiverse visual is assigned to multiple links: {visual_path}")
+        visual_paths.add(visual_path)
+        visual_relatives.add(visual_relative)
+
+        collisions: list[_ArtiverseMeshResource] = []
+        for collision_index, collision in enumerate(collision_elements):
+            collision_path, _, collision_transform, collision_scale = (
+                _geometry_mesh_resource(
+                    collision,
+                    sdf_dir=sdf_dir,
+                    link_transform=link_transforms[link_name],
+                    label=f"Artiverse link {link_name!r} collision {collision_index}",
+                    allowed_suffixes=frozenset({".obj", ".gltf", ".glb"}),
+                )
+            )
+            previous_owner = collision_owners.setdefault(collision_path, link_name)
+            if previous_owner != link_name:
+                raise ValueError(
+                    f"Artiverse collision is assigned to multiple links: {collision_path}"
+                )
+            collisions.append(
+                _ArtiverseMeshResource(
+                    path=collision_path,
+                    transform=collision_transform,
+                    uniform_scale=collision_scale,
+                )
+            )
+        records.append(
+            _ArtiverseLinkMeshRecord(
+                link_name=link_name,
+                visual_mesh=_ArtiverseMeshResource(
+                    path=visual_path,
+                    transform=visual_transform,
+                    uniform_scale=visual_scale,
+                ),
+                collision_meshes=tuple(collisions),
+            )
+        )
+    if not records:
+        raise ValueError(f"Artiverse SDF contains no links: {sdf_path}")

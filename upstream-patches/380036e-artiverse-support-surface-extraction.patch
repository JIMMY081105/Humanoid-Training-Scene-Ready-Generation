+def _surface_interior_sample_points(surface: Any) -> tuple[np.ndarray, np.ndarray]:
+    """Return inset surface-local hull samples and their transformed 3D points."""
+
+    bounds_min = np.asarray(surface.bounding_box_min, dtype=float)
+    bounds_max = np.asarray(surface.bounding_box_max, dtype=float)
+    if (
+        bounds_min.shape != (3,)
+        or bounds_max.shape != (3,)
+        or not np.all(np.isfinite(bounds_min))
+        or not np.all(np.isfinite(bounds_max))
+        or np.any(bounds_max < bounds_min)
+    ):
+        raise ValueError(f"Support surface {surface.surface_id} has invalid bounds")
+
+    mesh = getattr(surface, "mesh", None)
+    if mesh is not None and len(mesh.vertices):
+        mesh_xy = np.asarray(mesh.vertices[:, :2], dtype=float)
+        if mesh_xy.ndim != 2 or mesh_xy.shape[1] != 2 or not np.all(
+            np.isfinite(mesh_xy)
+        ):
+            raise ValueError(
+                f"Support surface {surface.surface_id} has invalid mesh samples"
+            )
+        sample_min = np.min(mesh_xy, axis=0)
+        sample_max = np.max(mesh_xy, axis=0)
+    else:
+        sample_min = bounds_min[:2]
+        sample_max = bounds_max[:2]
+    if np.any(sample_max <= sample_min):
+        raise ValueError(
+            f"Support surface {surface.surface_id} has degenerate sample bounds"
+        )
+    fractions = np.linspace(0.1, 0.9, 5)
+    local_points = [
+        np.array(
+            [
+                sample_min[0] + fraction_x * (sample_max[0] - sample_min[0]),
+                sample_min[1] + fraction_y * (sample_max[1] - sample_min[1]),
+            ]
+        )
+        for fraction_x in fractions
+        for fraction_y in fractions
+    ]
+    if hasattr(surface, "contains_point_2d"):
+        local_points = [
+            point for point in local_points if surface.contains_point_2d(point)
+        ]
+    if not local_points:
+        raise ValueError(
+            f"Support surface {surface.surface_id} has no valid clearance samples"
+        )
+    local_array = np.asarray(local_points, dtype=float)
+    local_hom = np.column_stack(
+        [local_array, np.zeros(len(local_array)), np.ones(len(local_array))]
+    )
+    world_points = (surface.transform.GetAsMatrix4() @ local_hom.T).T[:, :3]
+    return local_array, world_points
+
+
+@dataclass(frozen=True)
+class _ArtiverseCollisionSupportMeasurement:
+    sample_count: int
+    hit_count: int
+    max_gap_m: float | None
+    max_allowed_gap_m: float
+
+    @property
+    def supported(self) -> bool:
+        return (
+            self.sample_count > 0
+            and self.hit_count == self.sample_count
+            and self.max_gap_m is not None
+            and self.max_gap_m <= self.max_allowed_gap_m
+        )
+

+def _load_artiverse_collision_unions(
+    records: list[_ArtiverseLinkMeshRecord],
+) -> tuple[trimesh.Trimesh, dict[str, trimesh.Trimesh]]:
+    """Load one exact collision union per SDF link and their global union."""
+
+    link_unions: dict[str, trimesh.Trimesh] = {}
+    for record in records:
+        if record.link_name in link_unions:
+            raise ValueError(
+                f"Duplicate normalized Artiverse collision link: {record.link_name}"
+            )
+        link_unions[record.link_name] = _load_artiverse_collision_union([record])
+    if not link_unions:
+        raise ValueError("Normalized Artiverse SDF has no collision links")
+    combined = trimesh.util.concatenate(list(link_unions.values()))
+    if not isinstance(combined, trimesh.Trimesh) or len(combined.faces) == 0:
+        raise ValueError("Normalized Artiverse collision union has no faces")
+    combined.merge_vertices(digits_vertex=4)
+    return combined, link_unions

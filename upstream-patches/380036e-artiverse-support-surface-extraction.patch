+def _load_artiverse_collision_union(
+    records: list[_ArtiverseLinkMeshRecord],
+) -> trimesh.Trimesh:
+    """Load every SDF-authored collision mesh in its publisher-authored frame."""
+
+    resources = [resource for record in records for resource in record.collision_meshes]
+    meshes = []
+    for resource in resources:
+        mesh = _load_and_prepare_mesh_with_up_axis(
+            resource.path,
+            source_is_y_up=resource.path.suffix.lower() in {".gltf", ".glb"},
+        )
+        if resource.uniform_scale != 1.0:
+            mesh.apply_scale(resource.uniform_scale)
+        mesh.apply_transform(resource.transform)
+        meshes.append(mesh)
+    if not meshes:
+        raise ValueError("Normalized Artiverse SDF has no collision meshes")
+    combined = trimesh.util.concatenate(meshes)
+    if not isinstance(combined, trimesh.Trimesh) or len(combined.faces) == 0:
+        raise ValueError("Normalized Artiverse collision union has no faces")
+    combined.merge_vertices(digits_vertex=4)
+    return combined

+def _measure_artiverse_same_link_collision_support(
+    surface: Any,
+    link_collision_meshes: dict[str, trimesh.Trimesh],
+    config: SupportSurfaceExtractionConfig,
+) -> _ArtiverseCollisionSupportMeasurement:
+    """Require every visual-hull sample to have nearby same-link collision below."""
+
+    _, world_points = _surface_interior_sample_points(surface)
+    link_name = getattr(surface, "link_name", None)
+    collision_mesh = link_collision_meshes.get(link_name)
+    max_allowed_gap = config.surface_offset_m + 0.02
+    if collision_mesh is None:
+        return _ArtiverseCollisionSupportMeasurement(
+            sample_count=len(world_points),
+            hit_count=0,
+            max_gap_m=None,
+            max_allowed_gap_m=max_allowed_gap,
+        )
+    ray_origins = world_points.copy()
+    ray_origins[:, 2] = (
+        float(surface.transform.translation()[2])
+        + config.self_intersection_threshold_m
+    )
+    ray_directions = np.tile([0, 0, -1], (len(ray_origins), 1))
+    locations, index_ray, _ = collision_mesh.ray.intersects_location(
+        ray_origins=ray_origins,
+        ray_directions=ray_directions,
+        multiple_hits=True,
+    )
+    nearest: dict[int, float] = {}
+    if len(locations):
+        raw_distances = np.linalg.norm(
+            locations - ray_origins[index_ray], axis=1
+        )
+        for ray_index, raw_distance in zip(index_ray, raw_distances):
+            raw_distance = float(raw_distance)
+            if raw_distance <= 1e-9:
+                continue
+            # Origins are raised by the self-intersection tolerance; report the
+            # physical gap below the actual support-surface origin.
+            gap = max(0.0, raw_distance - config.self_intersection_threshold_m)
+            previous = nearest.get(int(ray_index))
+            if previous is None or gap < previous:
+                nearest[int(ray_index)] = gap
+    return _ArtiverseCollisionSupportMeasurement(
+        sample_count=len(ray_origins),
+        hit_count=len(nearest),
+        max_gap_m=max(nearest.values()) if nearest else None,
+        max_allowed_gap_m=max_allowed_gap,
+    )
+
+
+def _tighten_surface_clearance_against_combined_mesh(
+    surface: Any,
+    combined_mesh: trimesh.Trimesh,
+    config: SupportSurfaceExtractionConfig,
+) -> float:
+    """Persist conservative all-ray clearance into the placement bounding box."""
+
+    bounds_min = np.asarray(surface.bounding_box_min, dtype=float)
+    bounds_max = np.asarray(surface.bounding_box_max, dtype=float)
+    _, ray_origins = _surface_interior_sample_points(surface)
+    surface_z = float(surface.transform.translation()[2])
+    ray_origins[:, 2] = surface_z + config.self_intersection_threshold_m
+    ray_directions = np.tile([0, 0, 1], (len(ray_origins), 1))
+    locations, index_ray, _ = combined_mesh.ray.intersects_location(
+        ray_origins=ray_origins,
+        ray_directions=ray_directions,
+        multiple_hits=True,
+    )
+
+    per_ray_distances: dict[int, float] = {}
+    if len(locations):
+        raw_distances = np.linalg.norm(
+            locations - ray_origins[index_ray], axis=1
+        )
+        for ray_index, raw_distance in zip(index_ray, raw_distances):
+            raw_distance = float(raw_distance)
+            if raw_distance <= config.self_intersection_threshold_m:
+                continue
+            distance = raw_distance + config.self_intersection_threshold_m
+            previous = per_ray_distances.get(int(ray_index))
+            if previous is None or distance < previous:
+                per_ray_distances[int(ray_index)] = distance
+    all_distances = np.array(
+        [
+            per_ray_distances.get(index, config.top_surface_clearance_m)
+            for index in range(len(ray_origins))
+        ],
+        dtype=float,
+    )
+    recomputed_clearance = min(
+        float(np.percentile(all_distances, config.clearance_percentile)),
+        config.max_measured_clearance_m,
+    )
+    authored_clearance = float(bounds_max[2] - bounds_min[2])
+    conservative_clearance = min(authored_clearance, recomputed_clearance)
+    tightened_max = bounds_max.copy()
+    tightened_max[2] = bounds_min[2] + conservative_clearance
+    surface.bounding_box_max = tightened_max
+    return conservative_clearance
+

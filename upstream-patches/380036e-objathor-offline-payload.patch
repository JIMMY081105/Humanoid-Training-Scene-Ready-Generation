 console_logger = logging.getLogger(__name__)
 
 
+def _xyz_array(values: object, *, label: str) -> np.ndarray:
+    """Convert ObjectThor ``{x,y,z}`` vectors to a finite NumPy array."""
+
+    if not isinstance(values, list) or not values:
+        raise ValueError(f"ObjectThor {label} must be a non-empty list")
+    try:
+        array = np.asarray(
+            [[value["x"], value["y"], value["z"]] for value in values],
+            dtype=np.float64,
+        )
+    except (KeyError, TypeError, ValueError) as exc:
+        raise ValueError(f"Malformed ObjectThor {label}") from exc
+    if array.ndim != 2 or array.shape[1] != 3 or not np.isfinite(array).all():
+        raise ValueError(f"Malformed ObjectThor {label} shape/values: {array.shape}")
+    return array
+
+
+def _load_objathor_payload(payload_path) -> trimesh.Trimesh:
+    """Build a textured Trimesh from the publisher's compressed THOR payload."""
+
+    with gzip.open(payload_path, "rb") as stream:
+        payload = pickle.load(stream)
+    if not isinstance(payload, dict):
+        raise ValueError(f"ObjectThor payload is not a mapping: {payload_path}")
+
+    vertices = _xyz_array(payload.get("vertices"), label="vertices")
+    faces = np.asarray(payload.get("triangles"), dtype=np.int64)
+    if faces.ndim == 1:
+        if len(faces) == 0 or len(faces) % 3:
+            raise ValueError(
+                "ObjectThor triangle index count is not divisible by three"
+            )
+        faces = faces.reshape((-1, 3))
+    if faces.ndim != 2 or faces.shape[1] != 3:
+        raise ValueError(f"Malformed ObjectThor triangle array: {faces.shape}")
+    if faces.min() < 0 or faces.max() >= len(vertices):
+        raise ValueError("ObjectThor triangle index is outside the vertex array")
+
+    normals = None
+    if payload.get("normals"):
+        candidate_normals = _xyz_array(payload["normals"], label="normals")
+        if len(candidate_normals) == len(vertices):
+            normals = candidate_normals
+
+    visual = None
+    if payload.get("uvs"):
+        try:
+            uvs = np.asarray(
+                [[value["x"], value["y"]] for value in payload["uvs"]],
+                dtype=np.float64,
+            )
+        except (KeyError, TypeError, ValueError) as exc:
+            raise ValueError("Malformed ObjectThor UV coordinates") from exc
+        albedo_name = str(payload.get("albedoTexturePath") or "albedo.jpg")
+        albedo_path = (
+            payload_path.parent / albedo_name.replace("\\", "/").split("/")[-1]
+        )
+        if (
+            len(uvs) == len(vertices)
+            and np.isfinite(uvs).all()
+            and albedo_path.is_file()
+        ):
+            with Image.open(albedo_path) as source_image:
+                image = source_image.convert("RGB").copy()
+            material = trimesh.visual.texture.SimpleMaterial(image=image)
+            visual = trimesh.visual.texture.TextureVisuals(
+                uv=uvs, material=material
+            )
+
+    mesh = trimesh.Trimesh(
+        vertices=vertices,
+        faces=faces,
+        vertex_normals=normals,
+        visual=visual,
+        process=False,
+    )
+    if mesh.is_empty:
+        raise ValueError(f"ObjectThor payload produced an empty mesh: {payload_path}")
+    return mesh
+
+

@@ -68,6 +68,80 @@ class TestOpeningPreservation(unittest.TestCase):
 
         return layout, tools
 
+    def test_navigation_common_zones_are_tool_authored_serialized_and_reset(self):
+        layout, tools = self._create_two_room_layout()
+        wall_id = next(
+            label
+            for label, endpoints in layout.boundary_labels.items()
+            if set(endpoints[:2]) == {"living_room", "kitchen"}
+        )
+        door_result = tools._add_door_impl(
+            wall_id=wall_id, position="left", width=0.9, height=2.1
+        )
+        assert door_result.success, door_result.message
+        backing_door_id = layout.doors[0].id
+        zones = [
+            {
+                "id": "shared_foyer",
+                "position": [0.0, 0.0],
+                "width": 2.0,
+                "depth": 1.0,
+                "reason": "A physical shared circulation strip for independent access.",
+                "carved_from": ["living_room"],
+                "connections": [
+                    {
+                        "id": "foyer_to_kitchen",
+                        "to": "kitchen",
+                        "backing_door_id": backing_door_id,
+                    }
+                ],
+            }
+        ]
+
+        result = tools._set_navigation_common_zones_impl(json.dumps(zones))
+
+        assert result.success, result.message
+        persisted = layout.to_dict()["navigation_common_zones"]
+        portal = persisted[0]["connections"][0]
+        assert portal["backing_door_id"] == backing_door_id
+        assert portal["width"] == 0.9
+        assert len(portal["position"]) == 2
+        assert portal["orientation"] in {"horizontal", "vertical"}
+        restored = HouseLayout.from_dict(layout.to_dict())
+        assert restored.navigation_common_zones == persisted
+
+        # A fresh placement cannot retain carve coordinates from the old plan.
+        rooms = [
+            {
+                "type": "classroom",
+                "prompt": "A replacement classroom",
+                "width": 5.0,
+                "depth": 4.0,
+            }
+        ]
+        replaced = tools._generate_room_specs_impl(json.dumps(rooms))
+        assert replaced.success
+        assert layout.navigation_common_zones == []
+
+    def test_navigation_common_zone_tool_rejects_unsafe_schema(self):
+        layout, tools = self._create_two_room_layout()
+        bad = [
+            {
+                "id": "shared_foyer",
+                "position": [0.0, 0.0],
+                "width": 2.0,
+                "depth": 1.0,
+                "reason": "too short",
+                "carved_from": ["unknown_room"],
+                "connections": [],
+            }
+        ]
+
+        result = tools._set_navigation_common_zones_impl(json.dumps(bad))
+
+        assert not result.success
+        assert layout.navigation_common_zones == []

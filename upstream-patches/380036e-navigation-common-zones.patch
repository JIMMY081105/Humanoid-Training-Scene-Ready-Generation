+    def _set_navigation_common_zones_impl(
+        self, navigation_common_zones_json: str
+    ) -> Result:
+        """Validate and persist JSON-native navigation common-zone metadata."""
+
+        console_logger.info("Tool called: set_navigation_common_zones(...)")
+        if not self.layout.placed_rooms:
+            return self._fail(
+                "Place rooms before setting navigation common zones."
+            )
+        try:
+            records = json.loads(navigation_common_zones_json)
+        except json.JSONDecodeError as exc:
+            return self._fail(f"Invalid navigation common-zone JSON: {exc}")
+        if not isinstance(records, list):
+            return self._fail("Navigation common zones must be a JSON array.")
+
+        room_ids = set(self.layout.room_ids)
+        zone_ids: set[str] = set()
+        for index, record in enumerate(records):
+            if not isinstance(record, dict):
+                return self._fail(f"Common zone {index} must be an object.")
+            zone_id = str(record.get("id") or "").strip()
+            if not zone_id or zone_id in room_ids or zone_id in zone_ids:
+                return self._fail(
+                    f"Common zone {index} has a missing, duplicate, or room-colliding ID."
+                )
+            zone_ids.add(zone_id)
+
+        portal_ids: set[str] = set()
+        for record in records:
+            zone_id = str(record["id"])
+            position = record.get("position")
+            dimensions = (record.get("width"), record.get("depth"))
+            if (
+                not isinstance(position, list)
+                or len(position) != 2
+                or not all(
+                    isinstance(value, (int, float)) and math.isfinite(value)
+                    for value in position
+                )
+                or not all(
+                    isinstance(value, (int, float))
+                    and math.isfinite(value)
+                    and value >= 0.9
+                    for value in dimensions
+                )
+            ):
+                return self._fail(
+                    f"Common zone {zone_id} needs finite position and width/depth >=0.9m."
+                )
+            if len(str(record.get("reason") or "").strip()) < 20:
+                return self._fail(
+                    f"Common zone {zone_id} needs an explicit circulation reason."
+                )
+            carved_from = record.get("carved_from")
+            if (
+                not isinstance(carved_from, list)
+                or not carved_from
+                or any(str(room_id) not in room_ids for room_id in carved_from)
+            ):
+                return self._fail(
+                    f"Common zone {zone_id}.carved_from must contain known room IDs."
+                )
+            connections = record.get("connections")
+            if not isinstance(connections, list) or not connections:
+                return self._fail(
+                    f"Common zone {zone_id} needs explicit connections."
+                )
+            has_backed_connection = False
+            for connection in connections:
+                if not isinstance(connection, dict):
+                    return self._fail(
+                        f"Common zone {zone_id} has a non-object connection."
+                    )
+                portal_id = str(connection.get("id") or "").strip()
+                endpoint = str(connection.get("to") or "").strip()
+                backing_door_id = str(
+                    connection.get("backing_door_id") or ""
+                ).strip()
+                if backing_door_id:
+                    door = next(
+                        (
+                            candidate
+                            for candidate in self.layout.doors
+                            if candidate.id == backing_door_id
+                        ),
+                        None,
+                    )
+                    if door is None:
+                        return self._fail(
+                            f"Common-zone portal {portal_id} backing door was not found."
+                        )
+                    door_rooms = {door.room_a, door.room_b}
+                    backing_rooms = door_rooms & set(carved_from)
+                    if endpoint not in door_rooms or len(backing_rooms) != 1:
+                        return self._fail(
+                            f"Common-zone portal {portal_id} backing door must join its endpoint to one carved room."
+                        )
+                    backing_room = next(iter(backing_rooms))
+                    placed = self.layout.get_placed_room(backing_room)
+                    opening_record = None
+                    if placed is not None:
+                        for wall in placed.walls:
+                            for opening in wall.openings:
+                                if opening.opening_id == backing_door_id:
+                                    opening_record = (wall, opening)
+                                    break
+                            if opening_record is not None:
+                                break
+                    if opening_record is None:
+                        return self._fail(
+                            f"Common-zone portal {portal_id} backing door has no generated wall opening."
+                        )
+                    wall, opening = opening_record
+                    dx = wall.end_point[0] - wall.start_point[0]
+                    dy = wall.end_point[1] - wall.start_point[1]
+                    wall_length = math.hypot(dx, dy)
+                    if wall_length <= 0.0:
+                        return self._fail(
+                            f"Common-zone portal {portal_id} backing wall is degenerate."
+                        )
+                    center_distance = (
+                        opening.position_along_wall + opening.width / 2.0
+                    )
+                    connection["width"] = float(opening.width)
+                    connection["position"] = [
+                        wall.start_point[0]
+                        + dx * center_distance / wall_length,
+                        wall.start_point[1]
+                        + dy * center_distance / wall_length,
+                    ]
+                    connection["orientation"] = (
+                        "horizontal" if abs(dx) >= abs(dy) else "vertical"
+                    )
+                    has_backed_connection = True
+                width = connection.get("width")
+                point = connection.get("position")
+                orientation = str(connection.get("orientation") or "").lower()
+                if not portal_id or portal_id in portal_ids:
+                    return self._fail(
+                        f"Common zone {zone_id} has a missing or duplicate portal ID."
+                    )
+                portal_ids.add(portal_id)
+                if endpoint not in room_ids | zone_ids or endpoint == zone_id:
+                    return self._fail(
+                        f"Common-zone portal {portal_id} has an invalid endpoint."
+                    )
+                if (
+                    not isinstance(width, (int, float))
+                    or not math.isfinite(width)
+                    or width < 0.9
+                ):
+                    return self._fail(
+                        f"Common-zone portal {portal_id} width must be >=0.9m."
+                    )
+                if (
+                    not isinstance(point, list)
+                    or len(point) != 2
+                    or not all(
+                        isinstance(value, (int, float)) and math.isfinite(value)
+                        for value in point
+                    )
+                    or orientation not in {"horizontal", "vertical"}
+                ):
+                    return self._fail(
+                        f"Common-zone portal {portal_id} needs a finite position and orientation."
+                    )
+            if not has_backed_connection:
+                return self._fail(
+                    f"Common zone {zone_id} needs at least one real backing_door_id."
+                )
+
+        # JSON round-trip provides a detached, JSON-only deep copy.
+        self.layout.navigation_common_zones = json.loads(json.dumps(records))
+        return Result(
+            success=True,
+            message=f"Stored {len(records)} navigation common zone(s).",
+        )
+

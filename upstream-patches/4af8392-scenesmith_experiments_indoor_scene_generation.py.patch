+    def load_existing_room_checkpoint(checkpoint_name: str, stage_label: str) -> bool:
+        """Load an existing room checkpoint when resuming an interrupted run."""
+        state_path = (
+            room_dir / "scene_states" / checkpoint_name / "scene_state.json"
+        )
+        if not state_path.exists():
+            return False
+
+        console_logger.info(
+            f"Reusing existing {stage_label} checkpoint for room {room_id}: "
+            f"{state_path}"
+        )
+        with open(state_path) as f:
+            checkpoint_state = json.load(f)
+        scene.restore_from_state_dict(checkpoint_state)
+        console_logger.info(
+            f"Loaded {len(scene.objects)} objects from {checkpoint_name}"
+        )
+        return True
+
+    if (
+        stop_stage == AgentType.MANIPULAND.value
+        and load_existing_room_checkpoint("final_scene", "final_scene")
+    ):
+        console_logger.info(
+            f"Skipping room {room_id}: final_scene checkpoint already exists"
+        )
+        return scene

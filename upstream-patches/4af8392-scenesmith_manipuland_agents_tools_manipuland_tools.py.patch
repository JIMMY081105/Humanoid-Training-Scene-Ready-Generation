+    def _translate_scene_object_world_z(
+        self, scene_obj: SceneObject, dz: float
+    ) -> None:
+        """Translate an object and any composite members upward in world Z."""
+        delta = RigidTransform(p=[0.0, 0.0, dz])
+        scene_obj.transform = delta @ scene_obj.transform
+
+        composite_type = scene_obj.metadata.get("composite_type")
+        if composite_type in ("stack", "pile"):
+            for member in scene_obj.metadata.get("member_assets", []):
+                if "transform" in member:
+                    member_transform = deserialize_rigid_transform(member["transform"])
+                    member["transform"] = serialize_rigid_transform(
+                        delta @ member_transform
+                    )
+        elif composite_type == "filled_container":
+            container_asset = scene_obj.metadata.get("container_asset")
+            if container_asset and "transform" in container_asset:
+                container_transform = deserialize_rigid_transform(
+                    container_asset["transform"]
+                )
+                container_asset["transform"] = serialize_rigid_transform(
+                    delta @ container_transform
+                )
+            for fill_asset in scene_obj.metadata.get("fill_assets", []):
+                if "transform" in fill_asset:
+                    fill_transform = deserialize_rigid_transform(
+                        fill_asset["transform"]
+                    )
+                    fill_asset["transform"] = serialize_rigid_transform(
+                        delta @ fill_transform
+                    )
+
+    def _compute_object_collisions(self, object_id: UniqueID) -> list:
+        """Return Drake collision pairs involving one object."""
+        cfg_physics = self.cfg.physics_validation
+        object_id_str = str(object_id)
+        collisions = compute_scene_collisions(
+            scene=self.scene,
+            penetration_threshold=cfg_physics.object_penetration_threshold_m,
+            floor_penetration_tolerance=cfg_physics.floor_penetration_tolerance_m,
+            current_furniture_id=self.current_furniture_id,
+            manipuland_furniture_tolerance_m=(
+                cfg_physics.manipuland_furniture_tolerance_m
+            ),
+        )
+        return [
+            collision
+            for collision in collisions
+            if object_id_str in (collision.object_a_id, collision.object_b_id)
+        ]
+
+    def _remove_if_placement_collides(
+        self,
+        object_id: UniqueID,
+        surface_id: str,
+        response_asset_id: str,
+    ) -> str | None:
+        """Remove a newly placed manipuland if Drake reports a collision.
+
+        Footprint and clearance checks only validate the requested surface frame.
+        Some extracted furniture surfaces can still sit inside the furniture's
+        collision mesh. This guard runs the same collision query exposed by the
+        physics tool, removes the offending object, and blocks further placement
+        on that support surface when the parent furniture collision is the cause.
+        """
+        object_id_str = str(object_id)
+
+        try:
+            object_collisions = self._compute_object_collisions(object_id)
+        except Exception as e:
+            console_logger.warning(
+                "Post-placement collision guard could not run for %s: %s",
+                object_id_str,
+                e,
+            )
+            return None
+
+        if not object_collisions:
+            return None
+
+        current_furniture_id = str(self.current_furniture_id)
+        total_lift_m = 0.0
+        lift_attempted = False
+        parent_collision = False
+        for _ in range(2):
+            parent_collisions = [
+                collision
+                for collision in object_collisions
+                if current_furniture_id
+                in (collision.object_a_id, collision.object_b_id)
+            ]
+            parent_collision = bool(parent_collisions)
+            if not parent_collision:
+                break
+
+            max_penetration = max(
+                collision.penetration_depth for collision in parent_collisions
+            )
+            remaining_lift = self._max_parent_collision_lift_m - total_lift_m
+            lift_m = min(
+                max_penetration + self._collision_lift_margin_m,
+                remaining_lift,
+            )
+            if lift_m <= 0.001:
+                break
+
+            obj = self.scene.get_object(object_id)
+            if obj is None:
+                break
+
+            self._translate_scene_object_world_z(obj, lift_m)
+            total_lift_m += lift_m
+            lift_attempted = True
+            console_logger.info(
+                "Lifted %s by %.3fm after parent collision on %s; "
+                "rechecking physics",
+                object_id_str,
+                lift_m,
+                surface_id,
+            )
+
+            try:
+                object_collisions = self._compute_object_collisions(object_id)
+            except Exception as e:
+                console_logger.warning(
+                    "Post-lift collision recheck failed for %s: %s",
+                    object_id_str,
+                    e,
+                )
+                return None
+
+            if not object_collisions:
+                console_logger.info(
+                    "Post-placement collision cleared for %s after %.3fm lift",
+                    object_id_str,
+                    total_lift_m,
+                )
+                return None
+
+        if parent_collision:
+            self._rejected_support_surfaces.add(surface_id)
+
+        obj = self.scene.get_object(object_id)
+        object_name = obj.name if obj else object_id_str
+        self.scene.remove_object(object_id)
+
+        collision_summary = "; ".join(
+            collision.to_description() for collision in object_collisions[:3]
+        )
+        if len(object_collisions) > 3:
+            collision_summary += f"; +{len(object_collisions) - 3} more"
+
+        surface_message = (
+            f" Surface {surface_id} is now blocked for this furniture because "
+            "its support plane appears to intersect the parent collision mesh."
+            if parent_collision
+            else ""
+        )
+        lift_message = (
+            f" Auto-lifted by {total_lift_m:.3f}m before removal, but "
+            "collision validation still failed."
+            if lift_attempted
+            else ""
+        )
+        message = (
+            f"Rejected placement of '{object_name}' ({object_id_str}) on "
+            f"surface {surface_id}: collision mesh validation found "
+            f"{collision_summary}.{lift_message} The object was removed."
+            f"{surface_message} "
+            "Choose a different surface or skip this furniture; do not retry "
+            "this blocked surface."
+        )
+        console_logger.warning(message)
+
+        return self._create_placement_failure_result(
+            asset_id=response_asset_id,
+            message=message,
+            error_type=ManipulandErrorType.PHYSICS_RESOLUTION_FAILED,
+        )
+
+    def _blocked_surface_failure(self, surface_id: str, response_asset_id: str) -> str:
+        """Return a consistent failure for surfaces blocked by collision checks."""
+        return self._create_placement_failure_result(
+            asset_id=response_asset_id,
+            message=(
+                f"Surface {surface_id} is blocked because previous "
+                "post-placement collision validation found it intersects "
+                "the parent furniture collision mesh. Choose a different "
+                "surface or skip this furniture."
+            ),
+            error_type=ManipulandErrorType.PHYSICS_RESOLUTION_FAILED,
+        )
+
+    def _guard_composite_result(
+        self,
+        result_json: str,
+        surface_id: str,
+        object_id_field: str,
+    ) -> str:
+        """Run collision validation for newly created composite manipulands."""
+        try:
+            result = json.loads(result_json)
+        except json.JSONDecodeError:
+            return result_json
+
+        if not result.get("success"):
+            return result_json
+
+        object_id = result.get(object_id_field)
+        if not object_id:
+            return result_json
+
+        collision_failure = self._remove_if_placement_collides(
+            object_id=UniqueID(object_id),
+            surface_id=surface_id,
+            response_asset_id=str(object_id),
+        )
+        return collision_failure if collision_failure is not None else result_json
+

+class TestConcurrentActionLogging(unittest.TestCase):
+    """Tests that action-log read-modify-write publication is serialized."""
+
+    def test_concurrent_threads_preserve_entries_and_valid_json(self):
+        """Readers never see partial JSON and concurrent entries are not lost."""
+        with tempfile.TemporaryDirectory() as tmp_dir:
+            log_path = Path(tmp_dir) / "action_log.json"
+            _append_action_to_log(
+                log_path=log_path,
+                tool_name="seed",
+                arguments={"worker_id": -1, "action_index": -1},
+            )
+
+            writer_count = 8
+            actions_per_writer = 10
+            start_barrier = threading.Barrier(writer_count)
+            stop_reader = threading.Event()
+            reader_errors: list[Exception] = []
+
+            def read_repeatedly() -> None:
+                while not stop_reader.is_set():
+                    try:
+                        assert isinstance(load_action_log(log_path), list)
+                    except Exception as exc:  # Captured and asserted in main thread.
+                        reader_errors.append(exc)
+                        stop_reader.set()
+
+            def append_actions(worker_id: int) -> None:
+                start_barrier.wait(timeout=10)
+                for action_index in range(actions_per_writer):
+                    _append_action_to_log(
+                        log_path=log_path,
+                        tool_name="thread_action",
+                        arguments={
+                            "worker_id": worker_id,
+                            "action_index": action_index,
+                        },
+                    )
+
+            reader = threading.Thread(target=read_repeatedly, daemon=True)
+            reader.start()
+            try:
+                with ThreadPoolExecutor(max_workers=writer_count) as executor:
+                    list(executor.map(append_actions, range(writer_count)))
+            finally:
+                stop_reader.set()
+                reader.join(timeout=10)
+
+            self.assertFalse(reader.is_alive())
+            self.assertEqual(reader_errors, [])
+            with open(log_path, encoding="utf-8") as log_file:
+                log_entries = json.load(log_file)
+
+            self.assertEqual(
+                len(log_entries), 1 + writer_count * actions_per_writer
+            )
+            self.assertEqual(
+                [entry["step_number"] for entry in log_entries],
+                list(range(1, len(log_entries) + 1)),
+            )
+            observed = {
+                (entry["arguments"]["worker_id"], entry["arguments"]["action_index"])
+                for entry in log_entries
+                if entry["tool_name"] == "thread_action"
+            }
+            expected = {
+                (worker_id, action_index)
+                for worker_id in range(writer_count)
+                for action_index in range(actions_per_writer)
+            }
+            self.assertEqual(observed, expected)
+
+    def test_concurrent_processes_preserve_every_entry(self):
+        """The sidecar lock serializes separate room-worker processes."""
+        with tempfile.TemporaryDirectory() as tmp_dir:
+            log_path = Path(tmp_dir) / "action_log.json"
+            process_count = 4
+            actions_per_process = 12
+            start_method = (
+                "fork"
+                if "fork" in multiprocessing.get_all_start_methods()
+                else "spawn"
+            )
+            context = multiprocessing.get_context(start_method)
+            start_event = context.Event()
+            processes = [
+                context.Process(
+                    target=_append_actions_in_process,
+                    args=(
+                        str(log_path),
+                        worker_id,
+                        actions_per_process,
+                        start_event,
+                    ),
+                )
+                for worker_id in range(process_count)
+            ]
+
+            try:
+                for process in processes:
+                    process.start()
+                start_event.set()
+                for process in processes:
+                    process.join(timeout=30)
+                self.assertTrue(
+                    all(not process.is_alive() for process in processes),
+                    "Concurrent action-log subprocess did not finish",
+                )
+                self.assertEqual(
+                    [process.exitcode for process in processes],
+                    [0] * process_count,
+                )
+            finally:
+                for process in processes:
+                    if process.is_alive():
+                        process.terminate()
+                        process.join(timeout=5)
+
+            with open(log_path, encoding="utf-8") as log_file:
+                log_entries = json.load(log_file)
+
+            self.assertEqual(
+                len(log_entries), process_count * actions_per_process
+            )
+            self.assertEqual(
+                [entry["step_number"] for entry in log_entries],
+                list(range(1, len(log_entries) + 1)),
+            )
+            observed = {
+                (entry["arguments"]["worker_id"], entry["arguments"]["action_index"])
+                for entry in log_entries
+            }
+            expected = {
+                (worker_id, action_index)
+                for worker_id in range(process_count)
+                for action_index in range(actions_per_process)
+            }
+            self.assertEqual(observed, expected)
+
+    def test_failed_atomic_replace_preserves_previous_document(self):
+        """A publication failure leaves the previous JSON valid and unchanged."""
+        with tempfile.TemporaryDirectory() as tmp_dir:
+            log_path = Path(tmp_dir) / "action_log.json"
+            _append_action_to_log(
+                log_path=log_path,
+                tool_name="seed",
+                arguments={"value": 1},
+            )
+            original_bytes = log_path.read_bytes()
+
+            with patch(
+                "scenesmith.agent_utils.action_logger.os.replace",
+                side_effect=OSError("simulated interrupted publication"),
+            ):
+                with self.assertRaisesRegex(
+                    OSError, "simulated interrupted publication"
+                ):
+                    _append_action_to_log(
+                        log_path=log_path,
+                        tool_name="never_published",
+                        arguments={"value": 2},
+                    )
+
+            self.assertEqual(log_path.read_bytes(), original_bytes)
+            with open(log_path, encoding="utf-8") as log_file:
+                self.assertEqual(json.load(log_file)[0]["tool_name"], "seed")
+            self.assertEqual(
+                list(log_path.parent.glob(f".{log_path.name}.*.tmp")), []
+            )
+

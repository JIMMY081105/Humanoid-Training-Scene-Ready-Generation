+if os.name == "nt":
+    import msvcrt
+else:
+    import fcntl
+
+
+_ACTION_LOG_THREAD_LOCK = threading.Lock()
+_LOCK_RETRY_SECONDS = 0.01
+
+
+def _acquire_file_lock(lock_file) -> None:
+    """Acquire an exclusive OS lock for the action-log sidecar file."""
+    if os.name == "nt":
+        # msvcrt.locking() requires the locked byte to exist.
+        lock_file.seek(0, os.SEEK_END)
+        if lock_file.tell() == 0:
+            lock_file.write(b"\0")
+            lock_file.flush()
+        lock_file.seek(0)
+        while True:
+            try:
+                msvcrt.locking(lock_file.fileno(), msvcrt.LK_NBLCK, 1)
+                return
+            except OSError as exc:
+                if exc.errno not in (errno.EACCES, errno.EAGAIN, errno.EDEADLK):
+                    raise
+                time.sleep(_LOCK_RETRY_SECONDS)
+    else:
+        fcntl.flock(lock_file.fileno(), fcntl.LOCK_EX)
+
+
+def _release_file_lock(lock_file) -> None:
+    """Release an action-log sidecar file lock acquired above."""
+    if os.name == "nt":
+        lock_file.seek(0)
+        msvcrt.locking(lock_file.fileno(), msvcrt.LK_UNLCK, 1)
+    else:
+        fcntl.flock(lock_file.fileno(), fcntl.LOCK_UN)
+
+
+@contextmanager
+def _exclusive_action_log_lock(log_path: Path) -> Iterator[None]:
+    """Serialize read-modify-write cycles across threads and processes.
+
+    The sidecar remains in place between writes. Removing a lock file after use
+    would allow a waiter to lock a different inode while another writer still
+    owns the original one.
+    """
+    lock_path = log_path.with_name(f".{log_path.name}.lock")
+    log_path.parent.mkdir(parents=True, exist_ok=True)
+    with _ACTION_LOG_THREAD_LOCK:
+        with open(lock_path, "a+b") as lock_file:
+            _acquire_file_lock(lock_file)
+            try:
+                yield
+            finally:
+                _release_file_lock(lock_file)
+
+
+def _fsync_parent_directory(directory: Path) -> None:
+    """Persist a completed rename on platforms that support directory fsync."""
+    if os.name == "nt":
+        # Windows does not support opening directories with os.open() for fsync.
+        return
+    flags = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0)
+    directory_fd = os.open(directory, flags)
+    try:
+        os.fsync(directory_fd)
+    finally:
+        os.close(directory_fd)
+
+
+def _write_action_log_atomically(log_path: Path, log_entries: list[dict]) -> None:
+    """Publish a complete JSON document without exposing a partial write."""
+    temporary_path: Path | None = None
+    try:
+        fd, temporary_name = tempfile.mkstemp(
+            dir=log_path.parent,
+            prefix=f".{log_path.name}.",
+            suffix=".tmp",
+        )
+        temporary_path = Path(temporary_name)
+        with os.fdopen(fd, "w", encoding="utf-8") as temporary_file:
+            json.dump(log_entries, temporary_file, indent=2)
+            temporary_file.flush()
+            os.fsync(temporary_file.fileno())
+        os.replace(temporary_path, log_path)
+        temporary_path = None
+        _fsync_parent_directory(log_path.parent)
+    except OSError as exc:
+        raise IOError(f"Failed to write action log to {log_path}: {exc}") from exc
+    finally:
+        if temporary_path is not None:
+            try:
+                temporary_path.unlink(missing_ok=True)
+            except OSError as cleanup_error:
+                console_logger.warning(
+                    "Failed to remove temporary action log %s: %s",
+                    temporary_path,
+                    cleanup_error,
+                )
+
 

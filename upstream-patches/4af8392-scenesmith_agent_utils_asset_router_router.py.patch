+    def _should_use_primitive_ceiling_fallback(self, item: AssetItem) -> bool:
+        """Return True for simple classroom ceiling assets HSSD often misses."""
+        if item.object_type != ObjectType.CEILING_MOUNTED:
+            return False
+
+        text = f"{item.short_name} {item.description}".lower()
+        if "projector" in text:
+            return True
+
+        has_light_term = any(
+            term in text
+            for term in (
+                "led",
+                "light panel",
+                "ceiling panel",
+                "troffer",
+                "recessed light",
+                "recessed panel",
+                "fluorescent",
+            )
+        )
+        has_flat_panel_term = any(
+            term in text
+            for term in (
+                "panel",
+                "rectangular",
+                "troffer",
+                "recessed",
+                "flush",
+                "slim",
+            )
+        )
+        return has_light_term and has_flat_panel_term
+
+    def _create_primitive_ceiling_fallback_geometry(
+        self, item: AssetItem, geometry_dir: Path
+    ) -> GeneratedGeometry | None:
+        """Create a simple ceiling mesh when retrieval fails.
+
+        The fallback is intentionally limited to classroom ceiling light panels and
+        projectors. It still goes through the normal mesh-to-SDF conversion path, so
+        collision geometry and physics validation remain in effect.
+        """
+        text = f"{item.short_name} {item.description}".lower()
+        if "projector" in text:
+            return self._create_primitive_projector_geometry(item, geometry_dir)
+        return self._create_primitive_ceiling_panel_geometry(item, geometry_dir)
+
+    def _create_primitive_ceiling_panel_geometry(
+        self, item: AssetItem, geometry_dir: Path
+    ) -> GeneratedGeometry | None:
+        """Create a shallow rectangular LED panel mesh."""
+        try:
+            width, depth, height = item.dimensions or [1.2, 0.3, 0.08]
+            width = max(float(width), 0.2)
+            depth = max(float(depth), 0.08)
+            height = max(float(height), 0.04)
+        except Exception:
+            width, depth, height = 1.2, 0.3, 0.08
+
+        safe_name = "".join(
+            ch if ch.isalnum() or ch in ("_", "-") else "_" for ch in item.short_name
+        ).strip("_")
+        safe_name = safe_name or "ceiling_led_panel"
+        geometry_path = (
+            geometry_dir / f"{safe_name}_primitive_panel_{int(time.time())}.glb"
+        )
+
+        try:
+            geometry_dir.mkdir(parents=True, exist_ok=True)
+            mesh = trimesh.creation.box(extents=(width, depth, height))
+            mesh.visual.face_colors = [240, 246, 255, 255]
+            mesh.export(geometry_path)
+        except Exception as e:
+            console_logger.error(
+                f"Primitive ceiling panel fallback failed for '{item.description}': {e}",
+                exc_info=True,
+            )
+            return None
+
+        console_logger.info(
+            f"Using primitive ceiling panel fallback for '{item.description}' "
+            f"at {geometry_path} ({width:.2f}m x {depth:.2f}m x {height:.2f}m)"
+        )
+        return GeneratedGeometry(
+            geometry_path=geometry_path,
+            item=item,
+            asset_source="generated",
+        )
+
+    def _create_primitive_projector_geometry(
+        self, item: AssetItem, geometry_dir: Path
+    ) -> GeneratedGeometry | None:
+        """Create a compact projector body with lens and short ceiling bracket."""
+        try:
+            width, depth, height = item.dimensions or [0.45, 0.35, 0.25]
+            width = max(float(width), 0.25)
+            depth = max(float(depth), 0.18)
+            height = max(float(height), 0.16)
+        except Exception:
+            width, depth, height = 0.45, 0.35, 0.25
+
+        safe_name = "".join(
+            ch if ch.isalnum() or ch in ("_", "-") else "_" for ch in item.short_name
+        ).strip("_")
+        safe_name = safe_name or "ceiling_projector"
+        geometry_path = (
+            geometry_dir / f"{safe_name}_primitive_projector_{int(time.time())}.glb"
+        )
+
+        try:
+            geometry_dir.mkdir(parents=True, exist_ok=True)
+
+            body_h = height * 0.58
+            body = trimesh.creation.box(extents=(width, depth * 0.82, body_h))
+            body.visual.face_colors = [238, 238, 232, 255]
+
+            lens = trimesh.creation.box(
+                extents=(width * 0.24, depth * 0.08, body_h * 0.32)
+            )
+            lens.apply_translation((0.0, -depth * 0.45, -body_h * 0.05))
+            lens.visual.face_colors = [24, 28, 34, 255]
+
+            bracket = trimesh.creation.box(
+                extents=(width * 0.14, depth * 0.14, height * 0.28)
+            )
+            bracket.apply_translation((0.0, 0.0, body_h * 0.5 + height * 0.14))
+            bracket.visual.face_colors = [170, 174, 178, 255]
+
+            mount_plate = trimesh.creation.box(
+                extents=(width * 0.42, depth * 0.34, height * 0.06)
+            )
+            mount_plate.apply_translation((0.0, 0.0, body_h * 0.5 + height * 0.31))
+            mount_plate.visual.face_colors = [210, 212, 214, 255]
+
+            scene = trimesh.Scene([body, lens, bracket, mount_plate])
+            scene.export(geometry_path)
+        except Exception as e:
+            console_logger.error(
+                f"Primitive projector fallback failed for '{item.description}': {e}",
+                exc_info=True,
+            )
+            return None
+
+        console_logger.info(
+            f"Using primitive projector fallback for '{item.description}' "

diff --git a/tests/unit/test_artiverse_rescale_provenance.py b/tests/unit/test_artiverse_rescale_provenance.py
new file mode 100644
index 0000000..5c60df7
--- /dev/null
+++ b/tests/unit/test_artiverse_rescale_provenance.py
@@ -0,0 +1,77 @@
+"""Artiverse copied-content evidence remains current after valid rescaling."""
+
+from types import SimpleNamespace
+
+from scenesmith.agent_utils import rescale_helpers
+from scenesmith.agent_utils.artiverse_visual_normalization import (
+    sha256_safe_directory_tree,
+)
+from scenesmith.agent_utils.rescale_helpers import (
+    _refresh_articulated_copy_provenance,
+)
+
+
+def test_refreshes_artiverse_normalization_and_copy_hashes_after_sdf_mutation(
+    tmp_path, monkeypatch
+):
+    asset_dir = tmp_path / "copied_asset"
+    asset_dir.mkdir()
+    sdf_path = asset_dir / "model.sdf"
+    sdf_path.write_text("<sdf><model name='before'/></sdf>", encoding="utf-8")
+    (asset_dir / "mesh.glb").write_bytes(b"mesh")
+    obj = SimpleNamespace(
+        metadata={
+            "articulated_source": "artiverse",
+            "articulated_copied_sdf_sha256": "stale",
+            "articulated_copied_tree_sha256": "stale",
+        }
+    )
+    calls = []
+
+    def normalize(copied_sdf, copied_root):
+        evidence = {
+            "schema_version": 2,
+            "status": "pass",
+            "policy": "publisher_glb_derived_external_gltf",
+            "copied_tree_sha256_after": sha256_safe_directory_tree(copied_root),
+        }
+        calls.append((copied_sdf, copied_root, evidence))
+        return evidence
+
+    monkeypatch.setattr(
+        rescale_helpers, "normalize_copied_artiverse_visuals", normalize
+    )
+
+    _refresh_articulated_copy_provenance([obj], sdf_path)
+    first_sdf_hash = obj.metadata["articulated_copied_sdf_sha256"]
+    first_tree_hash = obj.metadata["articulated_copied_tree_sha256"]
+    sdf_path.write_text("<sdf><model name='after'/></sdf>", encoding="utf-8")
+    _refresh_articulated_copy_provenance([obj], sdf_path)
+
+    assert obj.metadata["articulated_copied_sdf_sha256"] != first_sdf_hash
+    assert obj.metadata["articulated_copied_tree_sha256"] != first_tree_hash
+    assert len(calls) == 2
+    assert obj.metadata["artiverse_visual_normalization"] == calls[-1][2]
+    assert obj.metadata["articulated_copied_tree_sha256"] == calls[-1][2][
+        "copied_tree_sha256_after"
+    ]
+
+
+def test_non_artiverse_object_is_not_normalized_or_given_artiverse_evidence(
+    tmp_path, monkeypatch
+):
+    asset_dir = tmp_path / "copied_asset"
+    asset_dir.mkdir()
+    sdf_path = asset_dir / "model.sdf"
+    sdf_path.write_text("<sdf/>", encoding="utf-8")
+    obj = SimpleNamespace(metadata={"articulated_source": "artvip"})
+    monkeypatch.setattr(
+        rescale_helpers,
+        "normalize_copied_artiverse_visuals",
+        lambda *_args, **_kwargs: (_ for _ in ()).throw(
+            AssertionError("non-Artiverse normalization must not run")
+        ),
+    )
+
+    _refresh_articulated_copy_provenance([obj], sdf_path)
+
+    assert "articulated_copied_sdf_sha256" not in obj.metadata

+def _sha256_file(path: Path) -> str:
+    digest = hashlib.sha256()
+    with path.open("rb") as stream:
+        for chunk in iter(lambda: stream.read(1024 * 1024), b""):
+            digest.update(chunk)
+    return digest.hexdigest()
+
+
+def _sha256_directory_tree(root: Path) -> str:
+    return sha256_safe_directory_tree(root)
+
+
+def _refresh_articulated_copy_provenance(objects, sdf_path: Path) -> None:
+    """Refresh content bindings after an intentional in-room SDF rescale."""
+
+    relevant = [
+        obj
+        for obj in objects
+        if isinstance(getattr(obj, "metadata", None), dict)
+        and str(obj.metadata.get("articulated_source", "")).lower() == "artiverse"
+    ]
+    if not relevant:
+        return
+    normalization = normalize_copied_artiverse_visuals(sdf_path, sdf_path.parent)
+    sdf_hash = _sha256_file(sdf_path)
+    tree_hash = _sha256_directory_tree(sdf_path.parent)
+    if normalization["copied_tree_sha256_after"] != tree_hash:
+        raise RuntimeError(
+            "Artiverse copied-tree provenance changed after rescale normalization"
+        )
+    for obj in relevant:
+        obj.metadata["articulated_copied_sdf_sha256"] = sdf_hash
+        obj.metadata["articulated_copied_tree_sha256"] = tree_hash
+        obj.metadata["artiverse_visual_normalization"] = normalization
+
+

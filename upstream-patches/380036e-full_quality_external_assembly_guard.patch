+def _require_external_gated_assembly(pipeline_cfg: dict) -> bool:
+    """Reject direct post-floor-plan runs for the full-quality contract."""
+
+    policy = str(pipeline_cfg.get("final_assembly_policy", "builtin")).strip().lower()
+    allowed_policies = {"builtin", "external_artiverse_gated"}
+    if policy not in allowed_policies:
+        raise ValueError(
+            f"Invalid final_assembly_policy={policy!r}; expected one of "
+            f"{sorted(allowed_policies)}"
+        )
+
+    raw_env = os.environ.get("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY")
+    env_required = False
+    if raw_env is not None:
+        normalized = raw_env.strip().lower()
+        if normalized in {"1", "true", "yes", "on"}:
+            env_required = True
+        elif normalized not in {"0", "false", "no", "off", ""}:
+            raise ValueError(
+                "SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY must be a boolean value"
+            )
+
+    required = policy == "external_artiverse_gated" or env_required
+    stop_stage = str(pipeline_cfg.get("stop_stage", "")).strip().lower()
+    if required and stop_stage != "floor_plan":
+        raise RuntimeError(
+            "Direct SceneSmith post-floor-plan generation/assembly is disabled for "
+            "this full-quality contract. Use staged run_single_room_worker.py jobs "
+            "followed by scripts/assemble_final_house_and_render.py so compulsory "
+            "Artiverse placement and final survival are validated."
+        )
+    return required
+

diff --git a/tests/unit/test_full_quality_assembly_guard.py b/tests/unit/test_full_quality_assembly_guard.py
new file mode 100644
index 0000000..4071164
--- /dev/null
+++ b/tests/unit/test_full_quality_assembly_guard.py
@@ -0,0 +1,63 @@
+"""Tests for the opt-in full-quality external assembly guard."""
+
+import pytest
+
+from scenesmith.experiments.indoor_scene_generation import (
+    _require_external_gated_assembly,
+)
+
+
+def _pipeline(stop_stage="manipuland", policy="builtin"):
+    return {"stop_stage": stop_stage, "final_assembly_policy": policy}
+
+
+def test_default_builtin_pipeline_is_unchanged(monkeypatch):
+    monkeypatch.delenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", raising=False)
+    assert _require_external_gated_assembly(_pipeline()) is False
+
+
+def test_external_policy_allows_floor_plan_only(monkeypatch):
+    monkeypatch.delenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", raising=False)
+    assert (
+        _require_external_gated_assembly(
+            _pipeline("floor_plan", "external_artiverse_gated")
+        )
+        is True
+    )
+
+
+@pytest.mark.parametrize(
+    "stage", ["furniture", "wall_mounted", "ceiling_mounted", "manipuland"]
+)
+def test_external_policy_rejects_direct_room_or_assembly_stages(monkeypatch, stage):
+    monkeypatch.delenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", raising=False)
+    with pytest.raises(RuntimeError, match="Direct SceneSmith"):
+        _require_external_gated_assembly(
+            _pipeline(stage, "external_artiverse_gated")
+        )
+
+
+def test_environment_guard_tightens_builtin_policy(monkeypatch):
+    monkeypatch.setenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", "1")
+    with pytest.raises(RuntimeError, match="compulsory Artiverse"):
+        _require_external_gated_assembly(_pipeline())
+
+
+def test_false_environment_cannot_weaken_external_policy(monkeypatch):
+    monkeypatch.setenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", "false")
+    with pytest.raises(RuntimeError, match="compulsory Artiverse"):
+        _require_external_gated_assembly(
+            _pipeline("manipuland", "external_artiverse_gated")
+        )
+
+
+def test_invalid_policy_fails_closed(monkeypatch):
+    monkeypatch.delenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", raising=False)
+    with pytest.raises(ValueError, match="Invalid final_assembly_policy"):
+        _require_external_gated_assembly(_pipeline(policy="skip_checks"))
+
+
+def test_invalid_environment_value_fails_closed(monkeypatch):
+    monkeypatch.setenv("SCENESMITH_REQUIRE_GATED_FINAL_ASSEMBLY", "maybe")
+    with pytest.raises(ValueError, match="must be a boolean"):
+        _require_external_gated_assembly(_pipeline("floor_plan"))

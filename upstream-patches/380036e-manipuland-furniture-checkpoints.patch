+def _write_json_fsynced(path: Path, document: dict[str, Any]) -> None:
+    with path.open("x", encoding="utf-8", newline="\n") as handle:
+        json.dump(document, handle, indent=2, sort_keys=True)
+        handle.write("\n")
+        handle.flush()
+        os.fsync(handle.fileno())

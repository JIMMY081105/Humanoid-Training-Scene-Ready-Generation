+    @classmethod
+    def _install_offline_torch_hub_guard(
+        cls,
+    ) -> tuple[Any, list[str], Path] | None:
+        """Redirect DINOv2 torch-hub loads to the verified local cache.
+
+        The upstream DINO embedder defaults to ``source="github"``. PyTorch
+        Hub does not honor the Hugging Face offline variables and may contact
+        GitHub even when its source and weights are cached. Contract runs must
+        either use the one canonical local checkout or fail before a request.
+        """
+        offline_variables = (
+            "HF_HUB_OFFLINE",
+            "TRANSFORMERS_OFFLINE",
+            "DIFFUSERS_OFFLINE",
+        )
+        if not any(os.environ.get(name) == "1" for name in offline_variables):
+            return None
+
+        hub_root = Path(torch.hub.get_dir()).resolve()
+        source_candidates = sorted(hub_root.glob("facebookresearch_dinov2_*"))
+        main_candidates = [
+            path for path in source_candidates if path.name.endswith("_main")
+        ]
+        if main_candidates:
+            source_candidates = main_candidates
+        if len(source_candidates) != 1:
+            raise RuntimeError(
+                "Offline SAM3D requires exactly one cached DINOv2 source tree; "
+                f"found {[str(path) for path in source_candidates]}"
+            )
+        source_dir = source_candidates[0].resolve()
+        if not (source_dir / "hubconf.py").is_file():
+            raise RuntimeError(
+                f"Cached DINOv2 source has no hubconf.py: {source_dir}"
+            )
+
+        original_load = torch.hub.load
+        loaded_models: list[str] = []
+
+        def offline_load(
+            repo_or_dir: str,
+            model: str,
+            *args: Any,
+            source: str = "github",
+            **kwargs: Any,
+        ) -> Any:
+            is_official_dino = str(repo_or_dir) == "facebookresearch/dinov2"
+            is_bound_local = (
+                source == "local" and Path(repo_or_dir).resolve() == source_dir
+            )
+            if not (is_official_dino or is_bound_local):
+                raise RuntimeError(
+                    "Offline SAM3D blocked unexpected torch.hub load: "
+                    f"repo_or_dir={repo_or_dir!r}, source={source!r}"
+                )
+            weight_candidates = sorted(
+                (hub_root / "checkpoints").glob(f"{model}*.pth")
+            )
+            if len(weight_candidates) != 1:
+                raise RuntimeError(
+                    f"Offline SAM3D requires exactly one cached weight for "
+                    f"{model}; found {[str(path) for path in weight_candidates]}"
+                )
+            loaded_models.append(str(model))
+            return original_load(
+                str(source_dir), model, *args, source="local", **kwargs
+            )
+
+        torch.hub.load = offline_load
+        return original_load, loaded_models, source_dir
+

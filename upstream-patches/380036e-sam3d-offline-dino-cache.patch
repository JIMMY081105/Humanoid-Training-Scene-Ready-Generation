+def _release_transient_cuda_memory() -> None:
+    """Release request-scoped CUDA memory without unloading cached models.
+
+    Cleanup is deliberately best-effort so it never replaces the original
+    generation exception.  ``gc.collect`` clears Python reference cycles that
+    can retain SAM3D output tensors, while ``empty_cache`` returns only unused
+    allocator blocks; live model weights remain resident and unchanged.
+    """
+    try:
+        gc.collect()
+    except Exception:
+        console_logger.warning(
+            "Python garbage collection failed after a SAM3D request",
+            exc_info=True,
+        )
+
+    try:
+        if torch.cuda.is_available():
+            torch.cuda.empty_cache()
+    except Exception:
+        console_logger.warning(
+            "CUDA cache cleanup failed after a SAM3D request",
+            exc_info=True,
+        )
+
